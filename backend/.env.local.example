# 복사: cp .env.local.example .env.local
# 그 다음 값 채우기. .env.local 은 git ignored.

DJANGO_SECRET_KEY=django-insecure-dev-only-replace-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# DB (docker-compose interpolation 또는 직접 지정)
DATABASE_URL=postgresql://opscatalog:opscatalog@postgres:5432/ops_catalog_local

# 매니저 액션 hidden token (D15) — 충분히 긴 랜덤 문자열로 교체
MANAGE_TOKEN=replace-with-random-32+chars

# CORS (frontend 로컬)
CORS_ALLOWED_ORIGINS=http://localhost:3002

# 환경 표식
ENVIRONMENT=local
